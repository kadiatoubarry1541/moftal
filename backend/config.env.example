# Configuration PostgreSQL
# Copiez ce fichier en config.env et remplissez avec vos vraies valeurs.
# NE COMMITEZ JAMAIS config.env (il contient des secrets).

# --- Lier la base locale à la base en ligne (Neon/Render) ---
# Si vous définissez DATABASE_URL avec l'URL de votre base en ligne, le backend
# utilisera cette base au lieu de localhost. Ainsi "base locale" = même données que en ligne.
# DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# --- Base locale (utilisée seulement si DATABASE_URL n'est pas défini) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=enfants_adam_eve
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# Configuration JWT
# IMPORTANT: Changez cette clé secrète en production !
JWT_SECRET=your_secret_key_here_generate_a_random_string
JWT_EXPIRE=7d

# Configuration bcrypt
BCRYPT_ROUNDS=12

# Port du serveur
PORT=5002

# Environnement
NODE_ENV=development

# Configuration CORS
CORS_ORIGIN=http://localhost:5173

# Configuration des uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Mot de passe administrateur
# IMPORTANT: Changez ce mot de passe en production !
ADMIN_PASSWORD=your_admin_password_here
ADMIN_NUMERO_H=G0C0P0R0E0F0 0

# Envoyer la base locale vers Render (copie l'URL dans Render → PostgreSQL → Connection)
# RENDER_DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ─── URLs application ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5002

# ─── Flutterwave (paiement en ligne) ─────────────────────────────────────────
# Créez un compte sur https://dashboard.flutterwave.com
# Allez dans Settings → API Keys pour récupérer vos clés
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLW_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxx
# Hash de sécurité pour les webhooks (Settings → Webhooks dans le dashboard Flutterwave)
FLW_WEBHOOK_HASH=your_webhook_secret_hash_here

# ─── Abonnement professionnel ─────────────────────────────────────────────────
# Montant mensuel de l'abonnement en GNF (Francs Guinéens)
SUBSCRIPTION_PRICE=50000
SUBSCRIPTION_CURRENCY=GNF
# Durée de l'abonnement en jours (30 = 1 mois)
SUBSCRIPTION_DAYS=30

# ─── Email (Brevo) ───────────────────────────────────────────────────────────
# Créez un compte sur https://app.brevo.com → API Keys
BREVO_API_KEY=your_brevo_api_key_here
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASS=your_16_char_app_password
FROM_EMAIL=noreply@enfants-adam.app
FROM_NAME=Les Enfants d'Adam
