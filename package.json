{
  "name": "les-enfants-d-adam-main",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start:backend": "npm start --prefix backend",
    "start:frontend": "npm run dev --prefix frontend",
    "prestart:both": "node scripts/kill-ports.js",
    "start:both": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"cyan,magenta\" \"npm start --prefix backend\" \"npm run dev --prefix frontend\"",
    "setup": "npm run db:migrate:local --prefix backend && npm run db:seed --prefix backend",
    "deploy:backend": "npm run deploy --prefix backend",
    "build": "cd frontend && npm ci && npm run build",
    "start:edication": "npm run start:both --prefix edication",
    "start:edication:frontend": "npm run dev --prefix edication/frontend",
    "start:edication:backend": "npm run dev --prefix edication/backend",
    "start:clinique": "npm run start:both --prefix clinique",
    "start:clinique:frontend": "npm run dev --prefix clinique/frontend",
    "start:clinique:backend": "npm run dev --prefix clinique/backend",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "concurrently": "^8.2.0",
    "pptxgenjs": "^4.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "wrangler": "^4.100.0"
  }
}
